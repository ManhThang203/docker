# ============================================
# Database
# ============================================
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=blog_dev
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_PORT=23306

# ============================================
# App Database URL (used by blog-api / Prisma)
# ============================================
DATABASE_URL=mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@app-db:3306/${MYSQL_DATABASE}?allowPublicKeyRetrieval=true

# ============================================
# Redis
# ============================================
REDIS_PASSWORD=your_redis_password
REDIS_URL=redis://default:${REDIS_PASSWORD}@app-redis:6379
